{# Helper macro: render a sentiment bar out of 10 blocks #}
{% macro sentiment_bar(score) -%}
{%- set filled = (score // 10) | int -%}
{%- set empty = 10 - filled -%}
{{ "█" * filled }}{{ "░" * empty }}  {{ score }}%
{%- endmacro %}

